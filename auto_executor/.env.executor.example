# Конфигурация Автоматического Исполнителя Задач

# ============ ВЫБОР ПРОВАЙДЕРА LLM ============
# Доступные варианты: openai, anthropic, ollama, zai, custom
LLM_PROVIDER=openai

# ============ OPENAI НАСТРОЙКИ ============
# API ключ OpenAI (можно получить на https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Базовый URL OpenAI API (для совместимых API)
OPENAI_BASE_URL=https://api.openai.com/v1

# Модель OpenAI
OPENAI_MODEL=gpt-4

# ============ ANTHROPIC НАСТРОЙКИ ============
# API ключ Anthropic (можно получить на https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Модель Anthropic
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============ OLLAMA НАСТРОЙКИ (ЛОКАЛЬНЫЙ LLM) ============
# Базовый URL Ollama сервера
OLLAMA_BASE_URL=http://localhost:11434

# Модель Ollama (например: llama3, mistral, codellama)
# Убедитесь что модель загружена: ollama pull llama3
OLLAMA_MODEL=llama3

# ============ Z.AI НАСТРОЙКИ ============
# API ключ z.ai
ZAI_API_KEY=your-zai-api-key-here

# Базовый URL z.ai API
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Модель z.ai
ZAI_MODEL=glm-4.7

# ============ CUSTOM API НАСТРОЙКИ ============
# API ключ для кастомного API
CUSTOM_API_KEY=your-custom-api-key

# Базовый URL кастомного API
CUSTOM_BASE_URL=https://your-custom-api.com/v1

# Модель кастомного API
CUSTOM_MODEL=your-custom-model

# ============ НАСТРОЙКИ ВЫПОЛНЕНИЯ ============
# Автоматически продолжать без подтверждения (true/false)
AUTO_CONTINUE=false

# Сколько предыдущих задач включать в контекст (0-10)
MAX_CONTEXT_TASKS=3

# Позволить LLM выполнять bash команды (true/false)
# ⚠️  Опасно! Только для доверенных LLM!
USE_BASH_TOOLS=false
